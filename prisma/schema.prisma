generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  admin
  vendor
  customer
}

enum UserStatus {
  active
  inactive
  blocked
}

enum CertificationStatus {
  pending
  approved
  rejected
}

enum OrderStatus {
  pending
  confirmed
  cancelled
  delivered
}

model User {
  id           String     @id @default(uuid())
  name         String
  email        String     @unique
  password     String
  role         Role       @default(customer)
  status       UserStatus @default(active)
  profileImage String?
  otp          String?
  otpExpiry    DateTime?
  verified     Boolean    @default(false)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  vendorProfile  VendorProfile?
  orders         Order[]
  communityPosts CommunityPost[]
}

model VendorProfile {
  id                  String              @id @default(uuid())
  userId              String              @unique
  farmName            String
  certificationStatus CertificationStatus @default(pending)
  farmLocation        String
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  user                User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  produce             Produce[]
  rentalSpaces        RentalSpace[]
  orders              Order[]
  sustainabilityCerts SustainabilityCert[]
}

model Produce {
  id                  String              @id @default(uuid())
  vendorId            String
  name                String
  description         String?
  price               Float
  category            String
  certificationStatus CertificationStatus @default(pending)
  availableQuantity   Int                 @default(0)
  image               String?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  vendor VendorProfile @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  orders Order[]
}

model RentalSpace {
  id           String        @id @default(uuid())
  vendorId     String
  location     String
  size         Float
  price        Float
  availability Boolean       @default(true)
  image        String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  vendor VendorProfile @relation(fields: [vendorId], references: [id], onDelete: Cascade)
}

model Order {
  id        String      @id @default(uuid())
  userId    String
  produceId String
  vendorId  String
  quantity  Int         @default(1)
  status    OrderStatus @default(pending)
  orderDate DateTime    @default(now())
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  user    User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  produce Produce       @relation(fields: [produceId], references: [id], onDelete: Cascade)
  vendor  VendorProfile @relation(fields: [vendorId], references: [id], onDelete: Cascade)
}

model CommunityPost {
  id          String   @id @default(uuid())
  userId      String
  postContent String
  postDate    DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SustainabilityCert {
  id                String              @id @default(uuid())
  vendorId          String
  certifyingAgency  String
  certificationDate DateTime
  status            CertificationStatus @default(pending)
  documentUrl       String?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  vendor VendorProfile @relation(fields: [vendorId], references: [id], onDelete: Cascade)
}
